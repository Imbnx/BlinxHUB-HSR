{
  "name": "blinxhub",
  "productName": "BlinxHub",
  "version": "1.0.0",
  "description": "HSR Toolkit by BlinxHub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "builder": "electron builder-main.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.blinxhub.hsr",
    "productName": "BlinxHub",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "C:\\Users\\ezazu\\OneDrive\\Documents\\BlinxHSRHUB\\Screenshot 2026-04-15 014504.png"
    },
    "portable": {
      "artifactName": "BlinxHub-${version}.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}